# Copy to .env and fill in real values: cp .env.example .env

# ntfy (HTTP basic)
NTFY_URL=https://ntfy.example.com
NTFY_TOPIC=your-topic
NTFY_USER=your-ntfy-user
NTFY_PASS=your-ntfy-password

# Webhook / restart service (query token)
WEBHOOK_TOKEN=generate-a-long-random-secret
RESTART_URL=https://restart.example.com

# ESP32
ESP32_IP=192.168.1.10
# Token used in status_checker for GET /status on the device
ESP32_STATUS_TOKEN=your-esp32-status-token
# Token appended to ESP32 requests from webhook_new.py
ESP32_API_TOKEN=your-esp32-api-token
